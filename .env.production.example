# ─────────────────────────────────────────────────────────────────────────────
# OnlyDevs — Production Environment Variables
# Copy this file to .env.production (never commit it) and fill all values.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=https://onlydevs.store
NODE_ENV=production

# ── Database (Supabase MAIN project) ─────────────────────────────────────────
# Transaction pooler — port 6543 — used by Prisma at runtime
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Session pooler — pgbouncer=false — used by Prisma Migrate / generate
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── Auth (NextAuth / Auth.js) ─────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=

AUTH_URL=https://onlydevs.store

# Google OAuth — add https://onlydevs.store/api/auth/callback/google to
# "Authorized redirect URIs" in Google Cloud Console
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use sk_live_... / pk_live_... keys — NOT sk_test_
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_   # New webhook endpoint: https://onlydevs.store/api/webhooks/stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_

# ── Printful ─────────────────────────────────────────────────────────────────
PRINTFUL_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Verify domain onlydevs.store in Resend dashboard before sending
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@onlydevs.store

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────────────
# Create a new "onlydevs-prod" database in Upstash console
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# API token with Zone:DNS edit permission for onlydevs.store
CLOUDFLARE_API_TOKEN=
